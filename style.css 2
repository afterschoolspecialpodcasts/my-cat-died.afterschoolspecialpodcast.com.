/* =================================================================
   MY CAT DIED — After School with Friends Collective
   Refined external stylesheet
   Aesthetic: Sci-Fi Pop Art × Art Deco × Neon Glow × Poster Composition
   ================================================================= */

/* ---------- Tokens ---------- */
:root {
  --bg-base:        #0b001a;
  --bg-lifted:      #140028;
  --bg-secondary:   #1a0033;
  --bg-soft:        #f8f4ff;

  --gold:           #d4af37;
  --gold-warm:      #b8932e;
  --glow:           #f5d06f;
  --glow-soft:      rgba(245, 208, 111, 0.35);

  --text-light:     #ffffff;
  --text-dark:      #1a0033;
  --text-muted:     rgba(255, 255, 255, 0.82);
  --text-muted-2:   rgba(255, 255, 255, 0.7);

  --font-display:   'Playfair Display', Georgia, serif;
  --font-body:      'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

  --max-w:          1240px;
  --pad-section:    64px;
  --pad-section-m:  40px;
  --radius-sm:      4px;
  --radius-md:      10px;

  --glow-gold:      0 0 0 1px rgba(212, 175, 55, 0.45),
                    0 0 24px rgba(245, 208, 111, 0.22),
                    0 0 60px rgba(212, 175, 55, 0.14);
  --glow-button:    0 0 0 1px rgba(212, 175, 55, 0.6),
                    0 0 20px rgba(245, 208, 111, 0.4);
  --glow-button-hv: 0 0 0 1px rgba(245, 208, 111, 0.95),
                    0 0 32px rgba(245, 208, 111, 0.65),
                    0 0 60px rgba(245, 208, 111, 0.35);

  --ease:           cubic-bezier(0.4, 0, 0.2, 1);
  --header-h:       72px;
}

/* ---------- Reset ---------- */
*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  margin: 0;
  font-family: var(--font-body);
  font-weight: 400;
  line-height: 1.6;
  color: var(--text-light);
  background: var(--bg-base);
  overflow-x: hidden;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  position: relative;
}
img, video, iframe { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
input, textarea { font-family: inherit; }

.container {
  max-width: var(--max-w);
  margin: 0 auto;
  padding-left: 24px;
  padding-right: 24px;
  width: 100%;
}

.reveal {
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.7s var(--ease), transform 0.7s var(--ease);
}
.reveal.is-visible { opacity: 1; transform: translateY(0); }

/* =================================================================
   STAR BACKGROUND SYSTEM (visible — not faint)
   ================================================================= */
.page-bg {
  position: fixed;
  inset: 0;
  background: url("images/about-stars.png") center/cover no-repeat;
  background-attachment: fixed;
  opacity: 0.8;
  z-index: -2;
  pointer-events: none;
  animation: starDrift 90s linear infinite;
  will-change: transform;
}
.page-bg-community {
  background: url("images/community-background.PNG") center/cover no-repeat;
  background-attachment: fixed;
  opacity: 0.85;
  animation: none;
}
.page-overlay {
  position: fixed;
  inset: 0;
  background: rgba(11, 0, 26, 0.6);
  z-index: -1;
  pointer-events: none;
}
@keyframes starDrift {
  from { transform: translateY(0); }
  to   { transform: translateY(-60px); }
}

/* =================================================================
   HEADER
   ================================================================= */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 14px 0;
  background: rgba(11, 0, 26, 0.85);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(212, 175, 55, 0.18);
  transition: padding 0.3s var(--ease), background 0.3s var(--ease);
}
.site-header.scrolled {
  padding: 10px 0;
  background: rgba(11, 0, 26, 0.95);
  border-bottom-color: rgba(212, 175, 55, 0.3);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}
.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.brand img {
  width: 44px; height: 44px;
  border-radius: 50%;
  border: 1.5px solid var(--gold);
  object-fit: cover;
  box-shadow: 0 0 14px rgba(245, 208, 111, 0.3);
}
.brand-text {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: 0.16em;
  color: var(--gold);
}
.primary-nav { display: flex; gap: 28px; flex: 1; justify-content: center; }
.primary-nav a {
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-light);
  position: relative;
  padding: 4px 0;
  transition: color 0.25s var(--ease);
}
.primary-nav a::after {
  content: "";
  position: absolute;
  left: 0; bottom: -2px;
  width: 0; height: 1px;
  background: var(--gold);
  transition: width 0.3s var(--ease);
}
.primary-nav a:hover { color: var(--gold); }
.primary-nav a:hover::after,
.primary-nav a.active::after { width: 100%; }
.primary-nav a.active { color: var(--gold); }

.btn-collective {
  display: inline-block;
  padding: 9px 18px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid var(--gold);
  border-radius: 2px;
  white-space: nowrap;
  transition: background 0.25s var(--ease), color 0.25s var(--ease),
              box-shadow 0.25s var(--ease), transform 0.25s var(--ease);
  flex-shrink: 0;
}
.btn-collective:hover {
  background: var(--gold);
  color: var(--text-dark);
  box-shadow: 0 0 22px rgba(245, 208, 111, 0.5);
  transform: translateY(-1px);
}

.nav-toggle {
  display: none;
  width: 42px; height: 42px;
  padding: 9px;
  border: 1px solid rgba(212, 175, 55, 0.4);
  border-radius: var(--radius-sm);
  flex-direction: column;
  justify-content: space-between;
}
.nav-toggle span {
  display: block;
  height: 2px;
  background: var(--gold);
  transition: transform 0.3s var(--ease), opacity 0.3s var(--ease);
}
.nav-toggle.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
.nav-toggle.open span:nth-child(2) { opacity: 0; }
.nav-toggle.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

.mobile-menu {
  display: none;
  flex-direction: column;
  background: var(--bg-secondary);
  border-top: 1px solid rgba(212, 175, 55, 0.22);
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s var(--ease);
}
.mobile-menu.open { max-height: 500px; }
.mobile-menu a {
  padding: 16px 24px;
  border-bottom: 1px solid rgba(212, 175, 55, 0.08);
  font-size: 0.86rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-light);
  transition: color 0.2s var(--ease), background 0.2s var(--ease);
}
.mobile-menu a:last-child { border-bottom: none; }
.mobile-menu a:hover { color: var(--gold); background: rgba(212, 175, 55, 0.05); }
.mobile-collective { color: var(--gold) !important; }

/* =================================================================
   BUTTONS
   ================================================================= */
.btn {
  display: inline-block;
  padding: 13px 28px;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  border-radius: 2px;
  border: 1.5px solid transparent;
  white-space: nowrap;
  transition: transform 0.25s var(--ease), box-shadow 0.3s var(--ease),
              background 0.25s var(--ease), color 0.25s var(--ease),
              border-color 0.25s var(--ease);
}
.btn-large { padding: 16px 38px; font-size: 0.86rem; }
.btn-small { padding: 10px 22px; font-size: 0.72rem; letter-spacing: 0.18em; }
.btn-gold {
  background: transparent;
  color: var(--gold);
  border-color: var(--gold);
  box-shadow: var(--glow-button);
}
.btn-gold:hover {
  background: var(--gold);
  color: var(--text-dark);
  border-color: var(--glow);
  transform: translateY(-2px) scale(1.02);
  box-shadow: var(--glow-button-hv);
}
.btn-glow { box-shadow: var(--glow-button); }

/* =================================================================
   HERO — bright video, light overlay, text-shadow for legibility
   ================================================================= */
.hero {
  position: relative;
  padding-top: calc(var(--header-h) + 24px);
  padding-bottom: 48px;
  overflow: hidden;
  min-height: clamp(620px, 88vh, 900px);
  display: flex;
  align-items: center;
}

/* Light overlay only (per spec) */
.hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(11, 0, 26, 0.2);
  z-index: 1;
  pointer-events: none;
}

/* Floating ships */
.hero-ships {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}
.ship {
  position: absolute;
  display: block;
  pointer-events: none;
  will-change: transform;
}
.ship-1 {
  top: 12%;
  left: 8%;
  width: 11%;
  max-width: 160px;
  min-width: 70px;
  opacity: 0.85;
  filter: drop-shadow(0 0 16px rgba(245, 208, 111, 0.45));
  animation: ship-drift-1 14s ease-in-out infinite;
}
@keyframes ship-drift-1 {
  0%, 100% { transform: translate(0, 0); }
  25%      { transform: translate(10px, -8px); }
  50%      { transform: translate(0, -14px); }
  75%      { transform: translate(-8px, -6px); }
}
.ship-2 {
  top: 8%;
  right: 22%;
  width: 9%;
  max-width: 130px;
  min-width: 60px;
  opacity: 0.7;
  filter: drop-shadow(0 0 12px rgba(245, 208, 111, 0.4));
  animation: ship-drift-2 18s ease-in-out infinite;
}
@keyframes ship-drift-2 {
  0%, 100% { transform: translate(0, 0) rotate(-2deg); }
  33%      { transform: translate(-12px, 6px) rotate(-1deg); }
  66%      { transform: translate(8px, -8px) rotate(-3deg); }
}
.ship-3 {
  top: 24%;
  right: 6%;
  width: 7.5%;
  max-width: 110px;
  min-width: 50px;
  opacity: 0.6;
  filter: drop-shadow(0 0 10px rgba(245, 208, 111, 0.4));
  animation: ship-drift-3 22s ease-in-out infinite;
}
@keyframes ship-drift-3 {
  0%, 100% { transform: translate(0, 0); }
  50%      { transform: translate(-16px, -10px); }
}

/* Hero grid — text left, video right */
.hero-grid {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: 1fr 1.05fr;
  gap: 40px;
  align-items: center;
}

.hero-text {
  animation: fadeUp 1.1s var(--ease) both;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
/* Spec: text-shadow for legibility instead of darkening the video */
.hero-text {
  text-shadow: 0 4px 20px rgba(0, 0, 0, 0.8);
}

.hero-logo {
  width: 220px;
  height: auto;
  margin-bottom: 18px;
  filter: drop-shadow(0 0 20px rgba(245, 208, 111, 0.45));
}
.hero-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.6rem, 6.5vw, 5rem);
  letter-spacing: 0.02em;
  line-height: 0.95;
  margin: 0 0 12px;
  color: var(--gold);
  text-shadow: 0 0 40px rgba(245, 208, 111, 0.5),
               0 4px 18px rgba(0, 0, 0, 0.7);
}
.hero-tagline {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(1.1rem, 2.4vw, 1.5rem);
  color: var(--glow);
  margin: 0 0 28px;
  text-shadow: 0 4px 16px rgba(0, 0, 0, 0.7);
}
.hero-ctas {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}
.platform-icons {
  display: flex;
  gap: 10px;
  list-style: none;
  margin: 0;
  padding: 0;
}
.platform-icons a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(11, 0, 26, 0.55);
  border: 1px solid rgba(212, 175, 55, 0.55);
  color: var(--gold);
  transition: transform 0.25s var(--ease), color 0.25s var(--ease),
              border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
}
.platform-icons a:hover {
  color: var(--glow);
  border-color: var(--glow);
  transform: translateY(-2px);
  box-shadow: 0 0 18px rgba(245, 208, 111, 0.55);
}

/* =================================================================
   HERO VIDEO — bright, contained, responsive (per spec)
   ================================================================= */
.hero-video-wrapper {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}
.hero-video-glow {
  position: absolute;
  inset: -10%;
  background: radial-gradient(ellipse at center,
    rgba(245, 208, 111, 0.32) 0%,
    rgba(212, 175, 55, 0.18) 35%,
    transparent 70%);
  filter: blur(20px);
  animation: glow-pulse 5s ease-in-out infinite;
  pointer-events: none;
  z-index: -1;
}
@keyframes glow-pulse {
  0%, 100% { opacity: 0.7; }
  50%      { opacity: 1; }
}
.hero-video {
  width: 100%;
  max-width: 900px;
  display: block;
  margin: 0 auto;
  /* Per spec: brighten, don't darken */
  filter: brightness(1.2) contrast(1.1) saturate(1.1);
  border-radius: var(--radius-md);
}

/* =================================================================
   2. PODCAST STRIP
   ================================================================= */
.description {
  padding: 56px 0 40px;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(212, 175, 55, 0.1), transparent 50%),
    rgba(20, 0, 40, 0.6);
  text-align: center;
  position: relative;
  z-index: 1;
}
.description-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.4rem, 3.4vw, 2.1rem);
  margin: 0 0 12px;
  color: var(--gold);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.description-sub {
  margin: 0 auto;
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 720px;
  line-height: 1.65;
  font-style: italic;
}

/* =================================================================
   3. THREE-COLUMN GRID
   ================================================================= */
.trio {
  padding: 48px 0 72px;
  position: relative;
  z-index: 1;
  background:
    radial-gradient(ellipse at 0% 50%, rgba(107, 58, 160, 0.18), transparent 50%),
    radial-gradient(ellipse at 100% 50%, rgba(245, 208, 111, 0.06), transparent 50%),
    rgba(20, 0, 40, 0.6);
}
.trio-grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.trio-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32px 24px 28px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.06), rgba(11, 0, 26, 0.7));
  border: 1px solid var(--gold);
  border-radius: var(--radius-md);
  box-shadow: 0 0 0 1px rgba(212, 175, 55, 0.18),
              0 0 28px rgba(245, 208, 111, 0.08);
  transition: transform 0.3s var(--ease),
              border-color 0.3s var(--ease),
              box-shadow 0.3s var(--ease);
}
.trio-card:hover {
  transform: translateY(-4px);
  border-color: var(--glow);
  box-shadow: 0 0 0 1px rgba(245, 208, 111, 0.5),
              0 0 36px rgba(245, 208, 111, 0.3),
              0 0 80px rgba(212, 175, 55, 0.18);
}
.trio-art {
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}
.trio-art img {
  max-height: 130px;
  width: auto;
  object-fit: contain;
  filter: drop-shadow(0 0 18px rgba(245, 208, 111, 0.4));
}
.trio-card-center .trio-art img {
  animation: stamp-float 5s ease-in-out infinite;
}
.trio-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.35rem;
  margin: 0 0 8px;
  color: var(--gold);
  letter-spacing: 0.03em;
}
.trio-text {
  margin: 0 0 18px;
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.6;
  flex: 1;
}

/* =================================================================
   FEATURED EPISODE
   ================================================================= */
.featured {
  padding: var(--pad-section) 0;
  background:
    radial-gradient(ellipse at 80% 100%, rgba(107, 58, 160, 0.18), transparent 50%),
    rgba(11, 0, 26, 0.5);
  position: relative;
  z-index: 1;
}
.section-head { text-align: center; margin-bottom: 32px; }
.section-kicker {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--glow);
  margin-bottom: 10px;
  position: relative;
  padding: 0 24px;
  text-shadow: 0 0 12px rgba(245, 208, 111, 0.45);
}
.section-kicker::before,
.section-kicker::after {
  content: "";
  position: absolute;
  top: 50%;
  width: 14px; height: 1px;
  background: var(--glow);
  opacity: 0.6;
}
.section-kicker::before { left: 0; }
.section-kicker::after  { right: 0; }
.section-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.7rem, 3.8vw, 2.4rem);
  line-height: 1.15;
  margin: 0 0 12px;
  color: var(--text-light);
}
.section-sub {
  font-size: 1rem;
  color: var(--text-muted);
  max-width: 620px;
  margin: 0 auto;
  line-height: 1.65;
}

.featured-frame {
  max-width: 860px;
  margin: 0 auto;
  padding: 18px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.05), rgba(20, 0, 40, 0.6));
  border: 1px solid var(--gold);
  border-radius: var(--radius-md);
  box-shadow: var(--glow-gold);
  transition: box-shadow 0.3s var(--ease), transform 0.3s var(--ease);
}
.featured-frame:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 0 1px rgba(245, 208, 111, 0.6),
              0 0 32px rgba(245, 208, 111, 0.32),
              0 0 80px rgba(212, 175, 55, 0.18);
}
.featured-frame-spacer { margin-top: 48px; }
.spotify-embed {
  width: 100%;
  border: 0;
  border-radius: var(--radius-sm);
  background: var(--bg-secondary);
  display: block;
}

/* =================================================================
   PROUDLY PART OF
   ================================================================= */
.proudly {
  padding: var(--pad-section) 0;
  background:
    radial-gradient(ellipse at 50% 30%, rgba(245, 208, 111, 0.14), transparent 55%),
    radial-gradient(ellipse at 20% 80%, rgba(107, 58, 160, 0.25), transparent 50%),
    linear-gradient(180deg, rgba(26, 0, 51, 0.6), rgba(20, 0, 40, 0.5));
  position: relative;
  overflow: hidden;
  text-align: center;
  z-index: 1;
}
.proudly-compact { padding: 56px 0; }
.proudly-inner {
  position: relative;
  z-index: 1;
  max-width: 720px;
}
.proudly-stamp {
  width: 170px; height: 170px;
  margin: 0 auto 24px;
  object-fit: contain;
  filter: drop-shadow(0 0 30px rgba(245, 208, 111, 0.55));
  animation: stamp-float 5s ease-in-out infinite;
}
.proudly-compact .proudly-stamp { width: 140px; height: 140px; margin-bottom: 20px; }
@keyframes stamp-float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}
.proudly-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(1.5rem, 3.6vw, 2.2rem);
  margin: 0 0 24px;
  color: var(--text-light);
  text-shadow: 0 0 30px rgba(245, 208, 111, 0.3);
  line-height: 1.25;
}

/* =================================================================
   QUOTE
   ================================================================= */
.quote-section {
  padding: 72px 0;
  background:
    radial-gradient(ellipse at 50% 50%, rgba(212, 175, 55, 0.08), transparent 60%),
    rgba(11, 0, 26, 0.5);
  text-align: center;
  position: relative;
  z-index: 1;
}
.quote-section .container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18px;
}
.big-quote {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 700;
  font-size: clamp(1.4rem, 3.4vw, 2.3rem);
  line-height: 1.4;
  margin: 0;
  color: var(--gold);
  max-width: 880px;
  text-shadow: 0 0 24px rgba(245, 208, 111, 0.35);
}
.quote-stars {
  font-size: 1.6rem;
  color: var(--gold);
  text-shadow: 0 0 16px rgba(245, 208, 111, 0.7);
}

/* =================================================================
   ENHANCED FOOTER — cities flanking, socials, stars background
   ================================================================= */
.site-footer {
  position: relative;
  padding: 48px 0 24px;
  background: rgba(11, 0, 26, 0.7);
  border-top: 1px solid rgba(212, 175, 55, 0.22);
  text-align: center;
  overflow: hidden;
  z-index: 1;
}
.site-footer::before {
  content: "";
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 60%;
  max-width: 600px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--glow), transparent);
  opacity: 0.5;
}

.footer-cities {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
  opacity: 0.35;
}
.footer-city {
  position: absolute;
  bottom: 0;
  width: 50%;
  max-width: 580px;
  height: auto;
}
.footer-city-left  { left: -10%; }
.footer-city-right {
  right: -10%;
  transform: scaleX(-1);
}

.footer-inner {
  position: relative;
  z-index: 2;
}

.footer-socials {
  list-style: none;
  margin: 0 auto 22px;
  padding: 0;
  display: flex;
  justify-content: center;
  gap: 14px;
}
.footer-socials a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(20, 0, 40, 0.6);
  border: 1px solid rgba(212, 175, 55, 0.45);
  color: var(--gold);
  transition: transform 0.25s var(--ease), color 0.25s var(--ease),
              border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
}
.footer-socials a:hover {
  color: var(--glow);
  border-color: var(--glow);
  transform: translateY(-3px);
  box-shadow: 0 0 20px rgba(245, 208, 111, 0.5);
}

.footer-copy {
  margin: 0 0 4px;
  font-size: 0.92rem;
  letter-spacing: 0.04em;
  color: var(--text-light);
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: 0.06em;
}
.footer-credit {
  margin: 0;
  font-size: 0.78rem;
  letter-spacing: 0.04em;
  color: var(--text-muted-2);
}
.footer-credit a {
  color: var(--gold);
  transition: color 0.25s var(--ease), text-shadow 0.25s var(--ease);
}
.footer-credit a:hover {
  color: var(--glow);
  text-shadow: 0 0 12px rgba(245, 208, 111, 0.6);
}

/* =================================================================
   PAGE HERO (about / episodes / community / contact)
   ================================================================= */
.page-hero {
  padding-top: calc(var(--header-h) + 56px);
  padding-bottom: 36px;
  text-align: center;
  background: rgba(11, 0, 26, 0.5);
  border-bottom: 1px solid rgba(212, 175, 55, 0.12);
  position: relative;
  z-index: 1;
}
.page-title {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: clamp(2.2rem, 5.2vw, 3.4rem);
  line-height: 1.05;
  margin: 8px 0 12px;
  color: var(--gold);
  text-shadow: 0 0 30px rgba(245, 208, 111, 0.35);
}
.page-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 640px;
  margin: 0 auto;
  line-height: 1.65;
}
.page-hero-mic-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  text-align: left;
  flex-wrap: wrap;
}
.page-hero-mic-inner > div { text-align: left; }
.page-hero-icon {
  filter: drop-shadow(0 0 24px rgba(245, 208, 111, 0.55));
  animation: stamp-float 5s ease-in-out infinite;
}

/* =================================================================
   ABOUT PAGE
   ================================================================= */
.about-section {
  padding: var(--pad-section) 0;
  background: rgba(20, 0, 40, 0.55);
  position: relative;
  z-index: 1;
}
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
}
.about-image-frame {
  position: relative;
  border: 1px solid var(--gold);
  border-radius: var(--radius-md);
  padding: 12px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.06), rgba(20, 0, 40, 0.6));
  box-shadow: var(--glow-gold);
}
.about-image-frame img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-sm);
  display: block;
}
.about-text p {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0 0 14px;
}
.about-quote {
  margin: 22px 0;
  padding: 18px 22px;
  border-left: 2px solid var(--gold);
  background: rgba(212, 175, 55, 0.05);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.1rem;
  color: var(--text-light);
  line-height: 1.55;
}
.about-quote .quote-mark {
  font-family: var(--font-display);
  font-size: 3rem;
  line-height: 0;
  color: var(--gold);
  opacity: 0.55;
  vertical-align: -0.4em;
  margin-right: 4px;
}
.about-quote-cite {
  margin-top: 10px;
  font-size: 0.85rem;
  font-style: normal;
  letter-spacing: 0.15em;
  color: var(--gold);
  text-transform: uppercase;
}

/* =================================================================
   EPISODES PAGE
   ================================================================= */
.episodes {
  padding: var(--pad-section) 0;
  background: rgba(20, 0, 40, 0.55);
  position: relative;
  z-index: 1;
}
.episode-list {
  list-style: none;
  margin: 0 auto;
  padding: 0;
  max-width: 860px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.episode-card {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 16px 20px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.05), rgba(11, 0, 26, 0.7));
  border: 1px solid rgba(212, 175, 55, 0.32);
  border-radius: var(--radius-md);
  transition: transform 0.25s var(--ease),
              border-color 0.25s var(--ease),
              box-shadow 0.25s var(--ease);
}
.episode-card:hover {
  transform: translateY(-2px);
  border-color: var(--gold);
  box-shadow: 0 0 24px rgba(245, 208, 111, 0.25);
}
.episode-icon {
  flex-shrink: 0;
  filter: drop-shadow(0 0 14px rgba(245, 208, 111, 0.4));
}
.episode-meta { flex: 1; min-width: 0; }
.episode-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.18rem;
  margin: 0 0 4px;
  color: var(--gold);
  line-height: 1.25;
}
.episode-desc {
  margin: 0 0 6px;
  font-size: 0.92rem;
  color: var(--text-muted);
  line-height: 1.5;
}
.episode-stamp {
  margin: 0;
  font-size: 0.72rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--glow);
}
.episode-play {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 46px; height: 46px;
  border-radius: 50%;
  border: 1.5px solid var(--gold);
  color: var(--gold);
  background: rgba(11, 0, 26, 0.5);
  transition: background 0.25s var(--ease), color 0.25s var(--ease),
              transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
}
.episode-play:hover {
  background: var(--gold);
  color: var(--text-dark);
  transform: scale(1.08);
  box-shadow: 0 0 22px rgba(245, 208, 111, 0.6);
}
.episodes-more {
  text-align: center;
  margin: 36px 0 0;
}

/* =================================================================
   COMMUNITY PAGE
   ================================================================= */
.community-grid-section {
  padding: var(--pad-section) 0;
  background: rgba(20, 0, 40, 0.55);
  position: relative;
  z-index: 1;
}
.community-grid {
  list-style: none;
  margin: 0 auto 56px;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  max-width: 920px;
}
.community-card {
  padding: 26px 24px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.04), rgba(11, 0, 26, 0.72));
  border: 1px solid rgba(212, 175, 55, 0.28);
  border-radius: var(--radius-md);
  transition: transform 0.25s var(--ease),
              border-color 0.25s var(--ease),
              box-shadow 0.25s var(--ease);
}
.community-card:hover {
  transform: translateY(-3px);
  border-color: var(--gold);
  box-shadow: 0 0 26px rgba(245, 208, 111, 0.22);
}
.community-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 50px; height: 50px;
  border-radius: 50%;
  background: rgba(212, 175, 55, 0.12);
  border: 1px solid var(--gold);
  color: var(--gold);
  margin-bottom: 14px;
  box-shadow: 0 0 18px rgba(245, 208, 111, 0.25);
}
.community-card h3 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.2rem;
  margin: 0 0 6px;
  color: var(--gold);
}
.community-card p {
  margin: 0;
  font-size: 0.94rem;
  color: var(--text-muted);
  line-height: 1.6;
}
.community-collective {
  text-align: center;
  max-width: 720px;
  margin: 0 auto;
  padding: 40px 24px;
  background:
    radial-gradient(ellipse at 50% 30%, rgba(245, 208, 111, 0.12), transparent 60%),
    rgba(20, 0, 40, 0.7);
  border: 1px solid rgba(212, 175, 55, 0.35);
  border-radius: var(--radius-md);
  box-shadow: var(--glow-gold);
}
.community-stamp {
  margin: 0 auto 18px;
  filter: drop-shadow(0 0 30px rgba(245, 208, 111, 0.55));
  animation: stamp-float 5s ease-in-out infinite;
}
.community-collective h2 { line-height: 1.25; }
.community-collective p {
  color: var(--text-muted);
  font-size: 1rem;
  line-height: 1.65;
  margin: 0 auto 24px;
  max-width: 540px;
}

/* =================================================================
   CONTACT PAGE
   ================================================================= */
.contact-section {
  padding: var(--pad-section) 0;
  background: rgba(20, 0, 40, 0.55);
  position: relative;
  z-index: 1;
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  align-items: center;
}
.contact-image-frame {
  position: relative;
  border: 1px solid var(--gold);
  border-radius: var(--radius-md);
  padding: 12px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.06), rgba(20, 0, 40, 0.6));
  box-shadow: var(--glow-gold);
}
.contact-image-frame img {
  width: 100%;
  height: auto;
  border-radius: var(--radius-sm);
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 28px;
  background: linear-gradient(145deg, rgba(212, 175, 55, 0.04), rgba(11, 0, 26, 0.7));
  border: 1px solid rgba(212, 175, 55, 0.32);
  border-radius: var(--radius-md);
  box-shadow: 0 0 30px rgba(245, 208, 111, 0.1);
}
.field { display: flex; flex-direction: column; gap: 6px; }
.field label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
}
.field input,
.field textarea {
  background: rgba(11, 0, 26, 0.35);
  border: 1px solid rgba(212, 175, 55, 0.3);
  border-radius: var(--radius-sm);
  padding: 13px 14px;
  color: var(--text-light);
  font-size: 0.95rem;
  resize: vertical;
  transition: border-color 0.25s var(--ease),
              background 0.25s var(--ease),
              box-shadow 0.25s var(--ease);
}
.field input::placeholder,
.field textarea::placeholder { color: rgba(255, 255, 255, 0.4); }
.field input:focus,
.field textarea:focus {
  outline: none;
  border-color: var(--glow);
  background: rgba(11, 0, 26, 0.6);
  box-shadow: 0 0 0 3px rgba(245, 208, 111, 0.18),
              0 0 20px rgba(245, 208, 111, 0.12);
}
.form-actions {
  flex-direction: row;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.form-note {
  font-size: 0.85rem;
  color: var(--glow);
  font-style: italic;
}
.form-note.error { color: #ff8a8a; }

/* =================================================================
   RESPONSIVE — 5 tiers
   >1060 | 769–1060 | ≤1024 | ≤768 | ≤480
   ================================================================= */

/* HERO VIDEO device-specific max-heights (per spec) */
@media (min-width: 1060px) {
  .hero-video { max-height: 80vh; }
}
@media (max-width: 1024px) {
  .hero-video { max-height: 65vh; }
}
@media (max-width: 768px) {
  .hero-video { max-height: 55vh; }
}
@media (max-width: 480px) {
  .hero-video { max-height: 50vh; }
}

/* Small desktop / large tablet */
@media (max-width: 1060px) {
  .container { padding-left: 20px; padding-right: 20px; }
  .primary-nav { gap: 22px; }
  .primary-nav a { font-size: 0.74rem; letter-spacing: 0.16em; }
  .btn-collective { padding: 8px 14px; font-size: 0.66rem; }
  .brand-text { font-size: 0.92rem; }

  .hero-grid { gap: 32px; }
  .hero-logo { width: 200px; }

  .trio-grid { gap: 18px; }
  .trio-card { padding: 26px 18px 24px; }

  .about-grid, .contact-grid { gap: 32px; }
}

/* iPad / tablet ≤1024 */
@media (max-width: 1024px) {
  .hero {
    padding-top: calc(var(--header-h) + 32px);
    padding-bottom: 40px;
    min-height: clamp(640px, 95vh, 980px);
  }
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 32px;
    text-align: center;
  }
  .hero-text { max-width: 600px; margin: 0 auto; }
  .hero-logo { margin-left: auto; margin-right: auto; }
  .hero-ctas { justify-content: center; }
  .hero-video-wrapper { order: 2; }

  .featured, .description, .proudly, .quote-section,
  .about-section, .episodes, .community-grid-section,
  .contact-section, .trio { padding: 56px 0; }
  .description { padding: 48px 0 36px; }
}

/* iPad mini / large phone ≤768 */
@media (max-width: 768px) {
  :root { --pad-section: var(--pad-section-m); --header-h: 64px; }
  .container { padding-left: 18px; padding-right: 18px; }

  /* Header → hamburger */
  .primary-nav { display: none; }
  .btn-collective { display: none; }
  .nav-toggle { display: flex; }
  .mobile-menu { display: flex; }
  .brand img { width: 38px; height: 38px; }
  .brand-text { font-size: 0.86rem; letter-spacing: 0.14em; }

  /* Hero */
  .hero {
    padding-top: calc(var(--header-h) + 24px);
    padding-bottom: 32px;
    min-height: auto;
  }
  .hero-logo { width: 160px; margin-bottom: 14px; }
  .hero-tagline { margin-bottom: 22px; }
  .ship-2 { display: none; }
  .ship-3 { display: none; }
  .ship-1 { width: 18%; min-width: 70px; top: 6%; left: 4%; }

  .btn { padding: 12px 24px; font-size: 0.76rem; }
  .btn-large { padding: 14px 30px; font-size: 0.8rem; }
  .btn-small { padding: 9px 18px; font-size: 0.7rem; }

  /* Trio → 2 then 1 col */
  .trio-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  .trio-card { padding: 22px 16px 20px; }
  .trio-art { height: 100px; }
  .trio-art img { max-height: 100px; }

  /* About / contact stack */
  .about-grid, .contact-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  .about-image-frame, .contact-image-frame {
    max-width: 460px;
    margin: 0 auto;
  }

  /* Episodes */
  .episode-card { padding: 14px 16px; gap: 14px; }
  .episode-icon { width: 48px; height: 48px; }
  .episode-title { font-size: 1.02rem; }

  /* Community */
  .community-grid { grid-template-columns: 1fr; gap: 14px; }
  .community-collective { padding: 32px 22px; }

  /* Featured */
  .featured-frame { padding: 12px; }
  .spotify-embed { height: 320px; }

  /* Proudly */
  .proudly-stamp { width: 130px; height: 130px; margin-bottom: 18px; }

  /* Form */
  .contact-form { padding: 22px 18px; }
  .form-actions { flex-direction: column; align-items: stretch; }
  .form-actions .btn { width: 100%; text-align: center; }

  /* Page hero mic */
  .page-hero-mic-inner {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
  .page-hero-mic-inner > div { text-align: center; }
  .page-hero-icon { width: 88px; height: 88px; }

  /* Footer */
  .site-footer { padding: 36px 0 20px; }
  .footer-cities { opacity: 0.22; }
}

/* Small phone ≤480 */
@media (max-width: 480px) {
  .container { padding-left: 14px; padding-right: 14px; }
  .site-header { padding: 10px 0; }

  .hero-logo { width: 140px; }
  .hero-ctas { width: 100%; flex-direction: column; align-items: stretch; gap: 12px; }
  .hero-ctas .btn { width: 100%; text-align: center; }
  .platform-icons { justify-content: center; gap: 10px; }
  .platform-icons a { width: 38px; height: 38px; }

  .description-title { font-size: 1.25rem; }
  .description-sub { font-size: 0.95rem; }

  .trio-grid { grid-template-columns: 1fr; gap: 14px; }
  .trio-card { padding: 24px 18px 22px; }

  .featured-frame { padding: 8px; }
  .spotify-embed { height: 300px; }

  .proudly-stamp { width: 110px; height: 110px; }

  .big-quote { font-size: 1.15rem; line-height: 1.45; }

  .episode-card { flex-wrap: wrap; }
  .episode-meta { flex: 1 1 calc(100% - 78px); }
  .episode-play { margin-left: auto; }

  .community-card { padding: 22px 18px; }
  .community-collective { padding: 28px 16px; }
  .community-stamp { width: 120px; height: 120px; }

  .footer-socials a { width: 38px; height: 38px; }
  .footer-copy { font-size: 0.85rem; }
  .footer-credit { font-size: 0.72rem; }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
  .reveal { opacity: 1; transform: none; }
}
